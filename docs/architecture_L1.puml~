@startuml
title Level 1: Single Spacecraft Point-Mass MVP

skinparam classAttributeIconSize 0

' --- 环境与世界 ---
class CelestialEnvironment {
    - epoch: Epoch
    - region: Region
    + get_gravity_acceleration(pos): Vector3D
    + step_time(dt): void
}

' --- 航天器实体 (质点模型) ---
class SpacecraftPointMass {
    - id: String
    - state: Vector6D {pos, vel}
    - mass: double
    - ballistic_coef: double
    + apply_impulse(dv): void
    + apply_force(f, dt): void
    + propagate(env, dt): void
}

' --- 地面测控系统 ---
class GroundStation {
    - location: Vector3D
    - comm_delay: double
    + send_telecommand(sc, command): void
    + receive_telemetry(sc): TelemetryData
    note right: 模拟地面测控回路\n包含轨道预报与指令上行
}

' --- 航天器 GNC (质点级) ---
class GNC_Subsystem {
    - target_orbit: OrbitElements
    - navigation_state: Vector6D
    + process_telecommand(cmd): void
    + run_orbit_maintenance(current_state): Vector3D
    + run_orbit_transfer(target): Vector3D
}

' --- 仿真调度 ---
class SimulationManager {
    - env: CelestialEnvironment
    - sc: SpacecraftPointMass
    - gnc: GNC_Subsystem
    - gs: GroundStation
    + run_loop(): void
}

SimulationManager *-- CelestialEnvironment
SimulationManager *-- SpacecraftPointMass
SimulationManager *-- GNC_Subsystem
SimulationManager *-- GroundStation

SpacecraftPointMass ..> CelestialEnvironment : "probed by"
GNC_Subsystem ..> SpacecraftPointMass : "controls"
GroundStation ..> GNC_Subsystem : "uplink/downlink"

@enduml