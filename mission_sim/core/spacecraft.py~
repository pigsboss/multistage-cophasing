import numpy as np

class SpacecraftPointMass:
    """
    航天器质点模型 (Level 1)
    职责：维护航天器动力学状态，处理冲量/持续推力，提供积分接口。
    """
    def __init__(self, spacecraft_id, initial_state, mass=1000.0, ballistic_coeff=2.2):
        """
        :param spacecraft_id: 航天器唯一标识
        :param initial_state: [x, y, z, vx, vy, vz] (SI单位: m, m/s)
        :param mass: 初始质量 (kg)
        :param ballistic_coeff: 面质比/阻力系数 (为后续大气/光压做预留)
        """
        self.id = spacecraft_id
        # 内部状态向量
        self.state = np.array(initial_state, dtype=float)
        self.mass = float(mass)
        self.ballistic_coeff = ballistic_coeff
        
        # 瞬时加速度累计 (用于存储当前步的所有非引力外力)
        self.external_acceleration = np.zeros(3)
        
        # 燃料消耗记录
        self.fuel_consumed = 0.0

    @property
    def position(self):
        return self.state[0:3]

    @property
    def velocity(self):
        return self.state[3:6]

    def apply_impulse(self, dv):
        """
        施加瞬时速度增量 (Ideal Maneuver)
        :param dv: [dv_x, dv_y, dv_z] (m/s)
        """
        self.state[3:6] += np.array(dv)

    def apply_thrust(self, force_vector):
        """
        施加持续推力 (Continuous Thrust)
        :param force_vector: [f_x, f_y, f_z] (Newton)
        """
        # 加速度 a = F / m
        accel = np.array(force_vector) / self.mass
        self.external_acceleration = accel

    def update_mass(self, m_dot, dt):
        """
        更新质量 (燃料消耗)
        :param m_dot: 质量变化率 (kg/s)
        :param dt: 步长 (s)
        """
        dm = m_dot * dt
        self.mass -= dm
        self.fuel_consumed += dm

    def get_derivative(self, env_gravity_accel):
        """
        获取状态导数
        :param env_gravity_accel: 由环境类计算提供的引力加速度 [ax, ay, az]
        :return: [vx, vy, vz, ax_total, ay_total, az_total]
        """
        vx, vy, vz = self.state[3:6]
        # 总加速度 = 环境引力 + 航天器自身推力产生的加速度
        ax_total = env_gravity_accel[0] + self.external_acceleration[0]
        ay_total = env_gravity_accel[1] + self.external_acceleration[1]
        az_total = env_gravity_accel[2] + self.external_acceleration[2]
        
        return np.array([vx, vy, vz, ax_total, ay_total, az_total])

    def __repr__(self):
        return f"Spacecraft(ID={self.id}, Mass={self.mass:.2f}kg, Pos={self.position})"
