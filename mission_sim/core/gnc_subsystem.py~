import numpy as np

class GNC_Subsystem:
    """
    航天器 GNC 子系统 (Level 1)
    职责：处理地面指令、进行轨道预报与偏差计算、输出推力控制量。
    """
    def __init__(self, sc_id):
        self.sc_id = sc_id
        # 内部导航状态 (估计值)
        self.estimated_state = None
        # 目标轨道/位置
        self.target_state = None
        
        # 控制开关
        self.is_active = True
        self.control_mode = "HOLD"  # "TRANSFER" 或 "MAINTENANCE"

    def process_telecommand(self, command):
        """
        处理来自地面站的上行指令
        :param command: 字典格式的指令集
        """
        if command["type"] == "ORBIT_MAINTENANCE":
            self.control_mode = "MAINTENANCE"
            if command["target"] is not None:
                self.target_state = np.array(command["target"])
        
        elif command["type"] == "ORBIT_TRANSFER":
            self.control_mode = "TRANSFER"
            self.target_state = np.array(command["target"])

    def update_navigation(self, obs_state):
        """
        更新导航估计 (Level 1 阶段直接使用观测值，不加复杂滤波)
        :param obs_state: 带有噪声的测量状态 [x, y, z, vx, vy, vz]
        """
        self.estimated_state = obs_state

    def compute_control_force(self, k_matrix=None):
        """
        计算控制力 (Newton)
        :param k_matrix: 外部传入的控制增益 (如 LQR 增益)
        :return: 推力向量 [fx, fy, fz]
        """
        if not self.is_active or self.estimated_state is None or self.target_state is None:
            return np.zeros(3)

        # 1. 计算状态偏差 (Error State)
        error = self.estimated_state - self.target_state
        
        # 2. 简单的比例反馈控制 (演示用)
        # 在实际 Level 1 运行中，这里会调用之前验证过的 LQR 逻辑
        if k_matrix is not None:
            # u = -K * x_err
            u = -k_matrix @ error
            return u
        
        return np.zeros(3)

    def __repr__(self):
        return f"GNC(ID={self.sc_id}, Mode={self.control_mode})"
