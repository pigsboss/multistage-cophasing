import numpy as np

class GroundStation:
    """
    地面测控站类 (Level 1)
    职责：模拟地面与航天器之间的遥测遥控回路，包含测量误差模拟和指令生成。
    """
    def __init__(self, station_id="GS01", sigma_pos=5.0, sigma_vel=0.01):
        """
        :param station_id: 地面站标识
        :param sigma_pos: 位置测量标准差 (m)
        :param sigma_vel: 速度测量标准差 (m/s)
        """
        self.id = station_id
        self.sigma_pos = sigma_pos
        self.sigma_vel = sigma_vel
        self.command_queue = []

    def receive_telemetry(self, spacecraft):
        """
        接收遥测数据 (含测量噪声)
        :param spacecraft: SpacecraftPointMass 实例
        :return: 观测到的状态向量 [x, y, z, vx, vy, vz]
        """
        true_state = spacecraft.state
        # 模拟高斯测量噪声
        pos_noise = np.random.normal(0, self.sigma_pos, 3)
        vel_noise = np.random.normal(0, self.sigma_vel, 3)
        
        obs_state = true_state + np.concatenate([pos_noise, vel_noise])
        return obs_state

    def send_telecommand(self, spacecraft, gnc_module, target_orbit=None):
        """
        发送遥控指令
        :param spacecraft: 目标航天器
        :param gnc_module: 航天器搭载的 GNC 模块
        :param target_orbit: 目标轨道参数 (Level 1 可简化为目标位置)
        """
        # 这里的指令可以是轨道维持的激活信号，或者是新的目标点
        command = {
            "type": "ORBIT_MAINTENANCE",
            "target": target_orbit,
            "timestamp": np.nan # 预留时间戳
        }
        # 将指令通过“上行链路”传递给 GNC
        gnc_module.process_telecommand(command)

    def __repr__(self):
        return f"GroundStation(ID={self.id}, Noise_P={self.sigma_pos}m)"
